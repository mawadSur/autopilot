# Autopilot — example environment file.
#
# Copy to .env (repo root) OR src/.env — src/config.py looks at both.
# Never commit a real .env. Keys here are placeholders.
#
# Sections are ordered by what you need first:
#   1. Prediction-market scanner + multi-agent orchestrator (REQUIRED for the active stack)
#   2. Social narrative agent (only needed if you run social-narrative-agent/)
#   3. Calibration model baseline (only needed once you train an XGBoost model)
#   4. Legacy crypto trading stack (only needed if you run src/main.py FastAPI / live_trader.py)
#   5. Trading config knobs (all have defaults; override only when you mean to)


# ────────────────────────────────────────────────────────────────────────────
# 1. PREDICTION-MARKET PIPELINE — required for the active stack
# ────────────────────────────────────────────────────────────────────────────

# Gemini powers every Gemini-backed agent (calibration, synthesis, news/reddit
# research, outcome review, data quality, iterative improver). Without it the
# scanner main.py falls back to a neutral judge result; the orchestrator does
# not work without it.
#
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash         # default; overrideable per agent
GEMINI_TIMEOUT_S=30
GEMINI_USE_SEARCH_GROUNDING=true

# GOOGLE_API_KEY is checked as a fallback by the outcome_review_agent + data
# quality auditor. Same key as GEMINI_API_KEY in practice. Leave unset if you
# already have GEMINI_API_KEY.
GOOGLE_API_KEY=

# OPTIONAL — only needed if you want the Python orchestrator to fetch live
# Reddit data via PRAW. For interactive Reddit research, use the
# /reddit-research skill (Devvit MCP) instead.
#
# Behaviour when REDDIT_CLIENT_ID is not set: src/reddit_research_agent/fetcher.py
# logs a one-time INFO notice and returns deterministic mock data (the same
# fixture used under RESEARCH_MOCK=true). The orchestrator stays runnable; the
# Reddit signal it sees is just synthetic.
#
# Create an app at https://www.reddit.com/prefs/apps (type: "script") if you
# want the live PRAW path.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=autopilot-reddit-research-agent/1.0

# Devvit MCP setup for interactive Reddit research (one-time, outside this file):
#
#   claude mcp add devvit -- npx -y @devvit/mcp
#
# Then in a Claude Code session: /reddit-research
# Replaces the PRAW path for one-off operator-driven Reddit analysis. The MCP
# is only available inside an interactive Claude Code session — CI / cron /
# headless paths still need either PRAW credentials above or RESEARCH_MOCK=true.


# ────────────────────────────────────────────────────────────────────────────
# 2. SOCIAL NARRATIVE AGENT — only for social-narrative-agent/main.py
# ────────────────────────────────────────────────────────────────────────────

# This standalone CLI uses OpenAI for structured claim extraction. The rest
# of the prediction-market stack does NOT need this key.
OPENAI_API_KEY=


# OPTIONAL — additive SQLite mirror of trade_execution_*.json + performance_audit.json.
# When set, the FastAPI /trades + /postmortems endpoints query SQLite (faster);
# build_dataset.py uses SQLite as the dataset source. JSON files remain canonical.
# Use src/storage/sync.py to (re)build the mirror from existing JSON files.
# AUTOPILOT_SQLITE_PATH=/Users/you/autopilot/autopilot.sqlite


# ────────────────────────────────────────────────────────────────────────────
# 3. CALIBRATION MODEL BASELINE — only needed AFTER you train a model
# ────────────────────────────────────────────────────────────────────────────

# Absolute path to the joblib-saved XGBoost model. When unset, the calibration
# agent loudly warns and falls back to a mock baseline (random jitter around
# market price). Set this once src/calibration_agent/train_xgboost.py has
# produced a model that passes evaluate_xgboost.py's quality gate.
#
# Example:
#   XGBOOST_MODEL_PATH=/Users/you/autopilot/model_artifacts/xgb_v1.joblib
XGBOOST_MODEL_PATH=


# ────────────────────────────────────────────────────────────────────────────
# 4. CRYPTO TRADING — exchange connectors, market data, ops
# ────────────────────────────────────────────────────────────────────────────
#
# REQUIRED for live + paper crypto trading. Start with a single exchange in
# testnet/sandbox mode; only enable live keys after the simulator + risk gates
# have been exercised end-to-end on paper.

# --- Primary spot exchange: Coinbase Advanced Trade (US-friendly) ---------
# Create at https://www.coinbase.com/settings/api with permissions:
# View + Trade. NEVER enable Withdraw on the bot's key.
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_API_PASSPHRASE=
COINBASE_USE_SANDBOX=true                 # flip to false ONLY after paper-trade validation

# --- Backup spot exchange: Kraken ----------------------------------------
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# --- Perpetuals venue (pick one) -----------------------------------------
# Hyperliquid (decentralized perps; uses an EVM private key, NOT API key)
# WARNING: this key controls funds. Use a dedicated wallet with only
# the capital you want exposed to the bot. Never reuse a personal wallet.
HYPERLIQUID_PRIVATE_KEY=
HYPERLIQUID_BASE_URL=https://api.hyperliquid.xyz

# OR Kraken Futures (centralized, regulated US-friendly perps)
KRAKEN_FUTURES_API_KEY=
KRAKEN_FUTURES_API_SECRET=
KRAKEN_FUTURES_DEMO=true                  # demo account flag

# --- Market data feeds ---------------------------------------------------
# Coinbase WebSocket — primary execution-venue feed (recommended for HFT).
# No API key required for the public market data channel.
COINBASE_WS_URL=wss://advanced-trade-ws.coinbase.com

# CoinDesk Data — legacy ETH 1m candle stream (kept for the existing model).
COINDESK_API_KEY=
COINDESK_WS_URL=wss://data-api.coindesk.com/streaming/spot
COINDESK_WS_MARKET=coinbase
COINDESK_WS_INSTRUMENT=ETH-USDT

# CryptoPanic — free crypto news RSS (sentiment + event-driven signals).
# https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=

# --- State + queue -------------------------------------------------------
# Redis stores live position state, rate-limit budgets, and concurrent-task
# locks. Local install: `brew install redis && brew services start redis`.
REDIS_URL=redis://localhost:6379/0

# --- Alerts (REQUIRED for unattended operation) --------------------------
# Discord webhook for log-level events (fills, errors, daily PnL summary).
# Create at: Server Settings -> Integrations -> Webhooks.
DISCORD_WEBHOOK_URL=

# Telegram bot for action-required alerts (kill-switch tripped, stuck order,
# margin call). Create via @BotFather; chat_id from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Monitoring ----------------------------------------------------------
# Sentry catches unhandled exceptions in the live trader. Free tier is plenty.
SENTRY_DSN=

# Grafana Cloud / Prometheus push gateway for time-series metrics
# (PnL curve, position exposure, fill latency, model confidence drift).
PROMETHEUS_PUSH_URL=
PROMETHEUS_PUSH_JOB=autopilot

# --- Risk + safety circuit breakers (RECOMMENDED to set explicitly) ------
# Daily realized-loss limit. Bot halts new entries when breached.
DAILY_LOSS_LIMIT_USD=1000

# Drawdown circuit breaker. Bot pauses ALL trading when peak-to-trough
# equity drawdown exceeds this percentage (e.g. 5.0 = 5%).
MAX_DRAWDOWN_PCT=5.0

# Maximum notional exposure across all open positions, USD.
MAX_TOTAL_NOTIONAL_USD=20000

# Per-symbol notional cap.
MAX_PER_SYMBOL_NOTIONAL_USD=5000

# Hard kill switch — write any value to this file path to halt the bot
# at the next decision tick. Bot checks this on every loop iteration.
KILL_SWITCH_FILE=/Users/you/autopilot/.kill_switch


# --- AWS / SageMaker (optional — only if training in the cloud) ----------
AWS_REGION=us-east-1
SAGEMAKER_ROLE_ARN=
MODEL_S3_PATH=
ENDPOINT_NAME=eth-endpoint
ENDPOINT_INSTANCE_TYPE=ml.m5.large
ENDPOINT_INSTANCES=1
SERVERLESS_MEMORY_MB=2048
SERVERLESS_MAX_CONCURRENCY=10


# ────────────────────────────────────────────────────────────────────────────
# 5. TRADING CONFIG (legacy ETH path) — all optional; defaults are sensible
# ────────────────────────────────────────────────────────────────────────────
# These map to TradingConfig fields in src/config.py. Listed here for
# discoverability; uncomment only when you intentionally override a default.
# Full list (~35 fields) lives in src/config.py — TradingConfig.

# Data + model paths
# DATA_DIR=eth_1m_data
# MODEL_DIR=model_sanity

# Position sizing / risk
# CAPITAL=10000
# RISK_PCT_PER_TRADE=0.004
# MAX_LEVERAGE=1.0
# ALLOW_SHORTS=false

# Model thresholds
# THR_LONG=0.75
# THR_SHORT=0.75
# MARGIN=0.25
# CONSENSUS=2
# USE_HARD_GATING=true

# Live trader
# SYMBOL=ETH/USDT
# INTERVAL_SEC=5.0
# TESTNET=true
# REAL=false
