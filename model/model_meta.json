{
  "model_type": "lstm_classifier",
  "framework": "pytorch",
  "feature_scaling": true,
  "scaler_type": "standard",
  "feature_cols": [
    "open",
    "high",
    "low",
    "close",
    "body",
    "range",
    "upper_wick",
    "lower_wick",
    "return",
    "sma_ratio",
    "ema_20",
    "macd",
    "rsi_14",
    "vol_change",
    "atr",
    "price_vs_hourly_trend",
    "bb_width",
    "vol_20",
    "vol_50",
    "vol_100",
    "vwap_ratio",
    "obv",
    "roc_14",
    "adx"
  ],
  "label_def": "triple_barrier_{-1,0,1}",
  "num_classes": 3,
  "price_col": "close",
  "window_size": 192,
  "tp_pct": 0.01,
  "sl_pct": 0.005,
  "time_limit": 30,
  "input_size": 24,
  "hidden_size": 768,
  "num_layers": 3,
  "dropout": 0.1,
  "bidirectional": true,
  "model_state_path": "model.pt",
