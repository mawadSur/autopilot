# ---------------------------------------------------------------------------
# Autopilot dashboard — environment variables
# Copy to .env.local for local dev; set the same keys in the Vercel project.
# ---------------------------------------------------------------------------

# Secret used to sign viewer session JWTs. Generate a long random value:
#   openssl rand -base64 48
SESSION_SECRET=

# Shared secret the local dashboard_exporter.py sends in the
# `x-exporter-secret` header when publishing snapshots to /api/ingest.
# Must match DASHBOARD_EXPORTER_SECRET on the exporter side.
#   openssl rand -base64 32
EXPORTER_SECRET=

# Vercel KV / Upstash Redis REST credentials.
# When you add a Vercel KV (Upstash) store to the project, Vercel injects
# KV_REST_API_URL + KV_REST_API_TOKEN automatically. If you provision Upstash
# directly instead, set UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN —
# the app reads either pair.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional: seconds before a published snapshot is considered stale (the UI
# shows a "stale" warning past this age). Default 120.
SNAPSHOT_TTL_SECONDS=120
